rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcılar - sadece kendi dokümanını okuyabilir, admin/müdür tümünü görebilir
    match /user/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.token.admin == true;
      allow update: if request.auth != null && (request.auth.uid == userId || request.auth.token.admin == true);
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Mağazalar - tüm giriş yapanlar okuyabilir, admin/müdür düzenleyebilir
    match /stores/{storeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role in ['ADMIN', 'MANAGER'];
    }

    // Satışlar - tüm giriş yapanlar okuyabilir, sadece kendi satışını yazabilir, admin/müdür tümünü düzenleyebilir
    match /sales/{saleId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.token.role in ['ADMIN', 'MANAGER'];
      allow delete: if request.auth != null && request.auth.token.role in ['ADMIN'];
    }

    // Çekiliş - tüm giriş yapanlar okuyabilir, admin/müdür yazabilir
    match /lottery/{lotteryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role in ['ADMIN', 'MANAGER'];
    }

    // Oylamalar - tüm giriş yapanlar okuyabilir/yazabilir
    match /polls/{pollId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Oylar - tüm giriş yapanlar okuyabilir/yazabilir
    match /votes/{voteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Temizlik - tüm giriş yapanlar okuyabilir/yazabilir
    match /cleaningSchedule/{docId} {
      allow read, write: if request.auth != null;
    }
    match /cleaningCompletions/{docId} {
      allow read, write: if request.auth != null;
    }

    // İzin Talepleri - tüm giriş yapanlar okuyabilir/yazabilir, admin/müdür düzenleyebilir
    match /leaveRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.token.role in ['ADMIN', 'MANAGER'];
    }

    // Aktivite Logu - sadece admin/müdür okuyabilir, tüm giriş yapanlar yazabilir
    match /activityLog/{logId} {
      allow read: if request.auth != null && request.auth.token.role in ['ADMIN', 'MANAGER'];
      allow create: if request.auth != null;
    }

    // Müşteriler - tüm giriş yapanlar okuyabilir/yazabilir
    match /customers/{customerId} {
      allow read, write: if request.auth != null;
    }

    // Envanter - tüm giriş yapanlar okuyabilir/yazabilir
    match /inventory/{itemId} {
      allow read, write: if request.auth != null;
    }
  }
}
